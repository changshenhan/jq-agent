# Copy to `.env` in the same directory you run `jq-agent` from (never commit `.env`).
# See README.md — Security section.

# JoinQuant jqdatasdk (策略脚本 `auth`，勿提交真实值)
# JQ_PHONE=
# JQ_PASSWORD=

# 底座模型（OpenAI 兼容 Chat + Embeddings；兼容旧名 JQ_OPENAI_*）
JQ_LLM_API_KEY=
JQ_LLM_BASE_URL=https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
JQ_MODEL=gpt-4o-mini
# JQ_EMBEDDING_MODEL=text-embedding-3-small
# --- LLM HTTP 延迟与吞吐（默认已启用 HTTP/2 + 连接池；见 README Performance）---
# JQ_LLM_HTTP2=true
# JQ_LLM_HTTP_CONNECT_TIMEOUT=15
# JQ_LLM_HTTP_READ_TIMEOUT=300
# JQ_LLM_HTTP_KEEPALIVE=32
# JQ_LLM_HTTP_MAX_CONNECTIONS=100
# index build 从 GitHub 拉源码时读超时（秒，默认 300；国内网络可改为 600）
# JQ_INDEX_GITHUB_TIMEOUT_SEC=600
# 文档索引输出目录（空则 ~/.jq-agent/jqdatasdk_index）；可设为项目相对路径如 jq_index，在 .env 写好后再执行 jq-agent index build
# JQ_DOC_INDEX_DIR=jq_index
# JQ_MAX_ITERATIONS=16
# JQ_LANG=zh
# --- Agent 行为（可选）---
# 任务路由：auto=关键词识别 jqdatasdk/聚宽后注入快路径；jq_sdk=始终快路径；general=关闭
# JQ_AGENT_TASK_MODE=auto
# JQ_LLM_STREAM=true
# JQ_PERMISSION_MODE=normal
# JQ_PERMISSION_MODE=strict
# JQ_USAGE_LOG=true
# JQ_AUTO_PARSE_BACKTEST_METRICS=true
# JQ_SESSION_BACKEND=sqlite
# JQ_SESSION_BACKEND=json
# JQ_SESSION_COMPACT_THRESHOLD=40
# JQ_SESSION_COMPACT_KEEP=12
# --- IDE Agent（Kilocode 类工作区工具；默认开启）---
# JQ_IDE_AGENT_TOOLS=true
# JQ_TERMINAL_TIMEOUT_SEC=120
# JQ_TERMINAL_MAX_OUTPUT_CHARS=48000
# --- GitHub 公开 API（搜索仓库/用户、查看公开主页；可选 token 提配额）---
# JQ_GITHUB_TOOLS=true
# JQ_GITHUB_TOKEN=ghp_...   # 或使用标准变量 GITHUB_TOKEN=
